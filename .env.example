# 复制此文件为 .env，填入你的 Key（.env 已在 .gitignore，不会提交到 Git）
# ⚠️ 不要把 API Key 发到聊天、截图或提交到 GitHub

# Kimi / 月之暗面（在 https://platform.moonshot.cn 获取）
MOONSHOT_API_KEY=sk-在这里填你的key

# 国内默认 api.moonshot.cn；海外可改为 https://api.moonshot.ai/v1
OPENAI_BASE_URL=https://api.moonshot.cn/v1

# 常用模型: moonshot-v1-8k | moonshot-v1-32k | kimi-k2.6
OPENAI_MODEL=moonshot-v1-8k
